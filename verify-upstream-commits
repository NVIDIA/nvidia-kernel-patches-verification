#set -x
set -euo pipefail

# Canonical upstream Linux kernel repository
DEFAULT_UPSTREAM_URL="https://github.com/torvalds/linux"
DEFAULT_UPSTREAM_BRANCH="master"

usage() {
    echo "Usage: $0 [-b branch] [-U upstream] [-q] [-n] [-v] [-t] <sha_list_file>"
    echo "  -b branch         Branch to check (default: current branch)"
    echo "  -U upstream       Upstream source: URL or remote/branch (default: $DEFAULT_UPSTREAM_URL)"
    echo "  -q                Quiet mode (only summary)"
    echo "  -n                Dry run (show what would be checked, don't execute)"
    echo "  -v                Verbose mode (enable debug output)"
    echo "  -t                Match by title: find reference commit on upstream by title instead of list SHA"
    echo ""
    echo "Example:"
    echo "    ~/kernel-patches-verification/verify-upstream-commits -U https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git ~/nvidia-kernel-patches-verification/grace-baremetal.txt"
    echo ""
    exit 1
}

BRANCH=""
UPSTREAM_ARG=""
QUIET=0
DRY_RUN=0
VERBOSE=0
BY_TITLE=0

# Support for -h and --help
for arg in "$@"; do
    if [ "$arg" = "-h" ] || [ "$arg" = "--help" ]; then
        usage
    fi
done

while getopts "b:U:qnvt" opt; do
    case $opt in
        b) BRANCH="$OPTARG" ;;
        U) UPSTREAM_ARG="$OPTARG" ;;
        q) QUIET=1 ;;
        n) DRY_RUN=1 ;;
        v) VERBOSE=1 ;;
        t) BY_TITLE=1 ;;
        *) usage ;;
    esac
done
shift $((OPTIND-1))

if [ "$#" -ne 1 ]; then
    usage
fi

SHA_LIST_FILE="$1"
if [ ! -f "$SHA_LIST_FILE" ]; then
    echo "File not found: $SHA_LIST_FILE" >&2
    exit 1
fi

# Enable debug output if verbose mode is set
if [ "$VERBOSE" -eq 1 ]; then
    set -x
fi

# Dry run mode - show configuration and exit (doesn't require git repo)
if [ "$DRY_RUN" -eq 1 ]; then
    SHA_COUNT=$(grep -v -E '^[[:space:]]*#|^[[:space:]]*$' "$SHA_LIST_FILE" | wc -l)
    echo "Dry run mode - configuration:"
    echo "  SHA list file: $SHA_LIST_FILE"
    echo "  SHAs to check: $SHA_COUNT"
    echo "  Target branch: ${BRANCH:-<current>}"
    echo "  Upstream:      ${UPSTREAM_ARG:-$DEFAULT_UPSTREAM_URL (default)}"
    echo "  Quiet mode:    $QUIET"
    echo "  Match by title: $BY_TITLE"
    exit 0
fi

# Check for Linux git repo in current directory or via LINUX_GIT
check_linux_repo() {
    local repo_dir="$1"
    if [ -d "$repo_dir/.git" ]; then
        return 0
    else
        return 1
    fi
}

if ! check_linux_repo "."; then
    if [ -z "${LINUX_GIT:-}" ] || ! check_linux_repo "${LINUX_GIT:-}"; then
        echo "Error: Not in a Linux git repo and LINUX_GIT is not set to a valid Linux git repo." >&2
        exit 1
    else
        cd "$LINUX_GIT" || { echo "Error: Cannot cd to '$LINUX_GIT'" >&2; exit 1; }
    fi
fi

if [ -z "$BRANCH" ]; then
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
fi

# Initialize counters (required for set -u)
EXISTS=0
REVIEW=0
ABSENT=0
BADSHA=0
TOTAL=0

output() {
    if [ "$QUIET" -eq 0 ]; then
        echo "$@"
    fi
}

# Setup upstream: determine if it's a URL or existing remote/branch
is_url() {
    [[ "$1" =~ ^(https?://|git://|ssh://|git@) ]]
}

setup_upstream() {
    local arg="${1:-$DEFAULT_UPSTREAM_URL}"

    if is_url "$arg"; then
        # It's a URL - fetch from it
        UPSTREAM_REMOTE="__upstream_check_tmp__"

        # Remove existing temporary remote if present
        if git remote | grep -qx "$UPSTREAM_REMOTE"; then
            git remote remove "$UPSTREAM_REMOTE" 2>/dev/null || true
        fi

        echo "Fetching upstream from $arg ($DEFAULT_UPSTREAM_BRANCH)..." >&2
        git remote add "$UPSTREAM_REMOTE" "$arg"
        git fetch --quiet "$UPSTREAM_REMOTE" "$DEFAULT_UPSTREAM_BRANCH"
        UPSTREAM="${UPSTREAM_REMOTE}/${DEFAULT_UPSTREAM_BRANCH}"
    else
        # It's an existing remote/branch reference
        UPSTREAM="$arg"
    fi
}

setup_upstream "$UPSTREAM_ARG"

# Unified cleanup: remove temporary upstream remote (if any) and branch log cache
BRANCH_LOG_CACHE=$(mktemp)
cleanup_all() {
    if [ -n "${UPSTREAM_REMOTE:-}" ]; then
        git remote remove "$UPSTREAM_REMOTE" 2>/dev/null || true
    fi
    rm -f "$BRANCH_LOG_CACHE" 2>/dev/null || true
}
trap cleanup_all EXIT

# Pre-cache branch commit log to avoid a full git-log scan per SHA entry
echo "Caching branch log for $BRANCH..." >&2
git log "$BRANCH" --no-merges --format='%H %s' > "$BRANCH_LOG_CACHE"

while IFS= read -r line; do
    # Skip lines that are only whitespace or comments
    [[ -z "${line//[[:space:]]/}" ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    # Parse line: first field is list SHA; optional " | TITLE" used in step 1 when -t is set
    SHA=$(echo "$line" | awk '{print $1}')
    TOTAL=$((TOTAL+1))
    STATUS=""
    ABBREV="------------"

    # 1. Resolve TITLE and REFERENCE_SHA (commit used for diff comparison and trailer check)
    if [ "$BY_TITLE" -eq 1 ]; then
        # Match by title: get title from list or from SHA, find reference commit on upstream by title
        if [[ "$line" =~ \|[[:space:]]*(.*) ]]; then
            TITLE="${BASH_REMATCH[1]}"
            TITLE="${TITLE#"${TITLE%%[![:space:]]*}"}"   # trim leading whitespace
        else
            TITLE=""
        fi
        if [ -z "$TITLE" ]; then
            # Need title from git; SHA must be in upstream or repo
            if git merge-base --is-ancestor "$SHA" "$UPSTREAM" 2>/dev/null; then
                TITLE=$(git log --format=%s -n 1 "$SHA")
            elif git rev-parse --verify "$SHA" 2>/dev/null; then
                TITLE=$(git log --format=%s -n 1 "$SHA")
            else
                output "$(printf "%-7s (%-8s) %s" "BADSHA" "$ABBREV" "$line")"
                BADSHA=$((BADSHA+1))
                continue
            fi
        fi
        TITLE_BASENAME=$(echo "$TITLE" | sed -E 's/^([A-Za-z0-9_/.-]+:[[:space:]]+)*SAUCE:[[:space:]]+//')
        REFERENCE_SHA=$(git log "$UPSTREAM" --no-merges --format='%H' --grep="$TITLE_BASENAME" --fixed-strings -n 1)
        if [ -z "$REFERENCE_SHA" ]; then
            output "$(printf "%-7s (%-8s) %s" "BADSHA" "$ABBREV" "$line")"
            BADSHA=$((BADSHA+1))
            continue
        fi
    else
        # Default: SHA must be in upstream; use it as reference
        if ! git merge-base --is-ancestor "$SHA" "$UPSTREAM" 2>/dev/null; then
            output "$(printf "%-7s (%-8s) %s" "BADSHA" "$ABBREV" "$line")"
            BADSHA=$((BADSHA+1))
            continue
        fi
        REFERENCE_SHA="$SHA"
        TITLE=$(git log --format=%s -n 1 "$SHA")
        TITLE_BASENAME=$(echo "$TITLE" | sed -E 's/^([A-Za-z0-9_/.-]+:[[:space:]]+)*SAUCE:[[:space:]]+//')
    fi

    # 2. Check if reference commit is present in branch (direct ancestor)
    if git merge-base --is-ancestor "$REFERENCE_SHA" "$BRANCH" 2>/dev/null; then
        ABBREV=$(git rev-parse --short=12 "$REFERENCE_SHA")
        output "$(printf "%-7s (%-8s) %s" "EXISTS" "$ABBREV" "$line")"
        EXISTS=$((EXISTS+1))
        continue
    fi

    # 3. Search for similar title in branch (ignore tags/prefixes)
    MATCH_FOUND=0
    REFERENCE_DIFF=$(git show --format= "$REFERENCE_SHA" | grep -E '^[+-][^+-]')
    while read -r commit_hash commit_title; do
        commit_title_basename=$(echo "$commit_title" | sed -E 's/^([A-Za-z0-9_/.-]+:[[:space:]]+)*SAUCE:[[:space:]]+//')
        if [[ "$commit_title_basename" == *"$TITLE_BASENAME"* ]]; then
            # 3a. Has cherry-pick/backport trailer? Compare diffs against reference commit.
            #     Trailer may reference list SHA or REFERENCE_SHA (e.g. after rebase with -t).
            #
            #    Cherry-picked from commit: $REFERENCE_SHA
            #    Cherry picked from commit: $REFERENCE_SHA
            #    Backported from commit: $REFERENCE_SHA
            #    commit $REFERENCE_SHA upstream
            #    Upstream commit $REFERENCE_SHA
            #
            if git log -1 --format=%B "$commit_hash" | grep -qi -E "Cherry[- ]picked from commit:?\s*($REFERENCE_SHA|$SHA)|Backported from commit:?\s*($REFERENCE_SHA|$SHA)|commit\s+($REFERENCE_SHA|$SHA)[0-9a-f]*\s+upstream|Upstream commit\s+($REFERENCE_SHA|$SHA)"; then
                # Compare diffs against reference commit
                ABBREV_LOCAL=$(git rev-parse --short=12 "$commit_hash")
                if diff -u -w \
                    <(echo "$REFERENCE_DIFF") \
                    <(git show --format= "$commit_hash" | grep -E '^[+-][^+-]') \
                    >/dev/null; then
                    output "$(printf "%-7s (%-8s) %s" "EXISTS" "$ABBREV_LOCAL" "$line")"
                    EXISTS=$((EXISTS+1))
                else
                    output "$(printf "%-7s (%-8s) %s" "REVIEW" "$ABBREV_LOCAL" "$line")"
                    REVIEW=$((REVIEW+1))
                fi
                MATCH_FOUND=1
                break
            else
                # 3b. Same title but no trailer (e.g. backported from list). Compare diffs.
                ABBREV_LOCAL=$(git rev-parse --short=12 "$commit_hash")
                if diff -u -w \
                    <(echo "$REFERENCE_DIFF") \
                    <(git show --format= "$commit_hash" | grep -E '^[+-][^+-]') \
                    >/dev/null; then
                    output "$(printf "%-7s (%-8s) %s" "EXISTS" "$ABBREV_LOCAL" "$line")"
                    EXISTS=$((EXISTS+1))
                else
                    output "$(printf "%-7s (%-8s) %s" "REVIEW" "$ABBREV_LOCAL" "$line")"
                    REVIEW=$((REVIEW+1))
                fi
                MATCH_FOUND=1
                break
            fi
        fi
    done < <(grep -F "$TITLE_BASENAME" "$BRANCH_LOG_CACHE")
    # No branch commit had matching title → report ABSENT
    if [ "$MATCH_FOUND" -eq 0 ]; then
        output "$(printf "%-7s (%-8s) %s" "ABSENT" "$ABBREV" "$line")"
        ABSENT=$((ABSENT+1))
    fi

done < "$SHA_LIST_FILE"

if [ "$QUIET" -eq 0 ]; then
    echo ""
fi
# Summary: counts of EXISTS, REVIEW, ABSENT, BADSHA
echo "Summary"
echo "_______"
printf "%-7s: %d\n" "EXISTS" "$EXISTS"
printf "%-7s: %d\n" "REVIEW" "$REVIEW"
printf "%-7s: %d\n" "ABSENT" "$ABSENT"
printf "%-7s: %d\n" "BADSHA" "$BADSHA"
printf "%-7s: %d\n" "Total"  "$TOTAL"
